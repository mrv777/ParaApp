# EAS Build ignore file
# This file overrides .gitignore for EAS builds
# See: https://docs.expo.dev/build-reference/eas-json/#easignore

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native builds
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.apk
*.aab

# Generated native folders
/ios
/android

# iOS
ios/Pods/
ios/.xcode.env.local

# Android
android/app/debug/
android/app/release/

# Native/Metro
.kotlin/
.metro-health-check*

# Environment (but NOT google-services.json - needed for builds)
.env
.env.local
.env.*.local
# google-services.json is NOT ignored here - EAS needs it for Android builds
paraapp-*.json

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
*.pem

# Testing
coverage/

# TypeScript
*.tsbuildinfo

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# Claude Code local files
.claude/CLAUDE.local.md
.claude/plans/

# Cloudflare Workers (not needed for mobile builds)
.wrangler/
server/
